rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidRecipe(data) {
      return data.menuName is string && data.menuName.size() <= 200
        && data.userId == request.auth.uid
        && data.createdAt == request.time
        && data.estimation is map
        && data.steps is list
        && data.analysis is map;
    }

    match /users/{userId} {
       allow read, write: if isOwner(userId);
       
       match /savedRecipes/{recipeId} {
         allow read, list: if isOwner(userId);
         allow create: if isOwner(userId) && isValidRecipe(incoming()) && isValidId(recipeId);
         allow delete: if isOwner(userId);
       }
    }
  }
}
